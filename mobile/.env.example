# Android emulator: 10.0.2.2 maps to host machine localhost
# Physical device (Expo Go) on same WiFi: use your PC LAN IP for API URLs, e.g. http://192.168.1.4:3001
EXPO_PUBLIC_AUTH_SERVICE_BASE_URL=http://10.0.2.2:3001
EXPO_PUBLIC_COMMERCE_SERVICE_BASE_URL=http://10.0.2.2:3003
EXPO_PUBLIC_SOCIAL_SERVICE_BASE_URL=http://10.0.2.2:3002
EXPO_PUBLIC_NOTIFICATION_SERVICE_BASE_URL=http://10.0.2.2:3005

# Rewrites localhost/127.0.0.1 in MinIO media URLs (avatars, post images).
# Android emulator ignores this and uses 10.0.2.2 automatically.
# Physical device: set to your PC LAN IP (no protocol), e.g. 192.168.1.4
EXPO_PUBLIC_DEV_HOST=192.168.1.4
