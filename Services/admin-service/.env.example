SERVER_PORT=3004
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DB_URL=jdbc:postgresql://localhost:5436/admin_db
DB_USERNAME=postgres
DB_PASSWORD=123456

REDIS_HOST=localhost
REDIS_PORT=6379

JWT_ACCESS_SECRET=change-me-access-secret-minimum-32-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-minimum-32-characters

# Kafka — hạng mục 1: bật cả producer + outbox publish để test gửi topic
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
ADMIN_KAFKA_PRODUCER_ENABLED=false
ADMIN_OUTBOX_PUBLISH_ENABLED=false
ADMIN_OUTBOX_RETRY_ENABLED=false
ADMIN_ENFORCEMENT_EXPIRATION_ENABLED=false

ADMIN_AUTH_INTEGRATION_ENABLED=false
ADMIN_AUTH_LOGIN_GATEWAY_ENABLED=false
ADMIN_COMMERCE_INTEGRATION_ENABLED=false
ADMIN_SOCIAL_INTEGRATION_ENABLED=false
