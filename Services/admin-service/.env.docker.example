DB_URL=jdbc:postgresql://postgres-admin:5432/admin_db
DB_USERNAME=postgres
DB_PASSWORD=123456

REDIS_HOST=redis
REDIS_PORT=6379

JWT_ACCESS_SECRET=acess_screet_6868_AKA_Phan_Tuan_Kiet_N22dccn145
JWT_REFRESH_SECRET=refresh_screet_9191_AKA_Phan_Tuan_Kiet_N22dccn145

KAFKA_BOOTSTRAP_SERVERS=kafka:19092
ADMIN_KAFKA_PRODUCER_ENABLED=true
ADMIN_OUTBOX_PUBLISH_ENABLED=true
