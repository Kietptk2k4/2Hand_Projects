# Docker Compose env template (safe to commit).
# Setup: cd Infrastructure && ./scripts/setup-docker-env.ps1

SERVER_PORT=3001
SPRING_PROFILES_ACTIVE=dev
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DB_URL=jdbc:postgresql://postgres-auth:5432/auth_db
DB_USERNAME=postgres
DB_PASSWORD=123456

REDIS_HOST=redis
REDIS_PORT=6379

JWT_ACCESS_SECRET=2hands-docker-dev-access-secret-min-32-chars
JWT_REFRESH_SECRET=2hands-docker-dev-refresh-secret-min-32-chars

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

AUTH_OAUTH2_SUCCESS_REDIRECT_URL=http://localhost:5173/oauth/success
AUTH_OAUTH2_FAILURE_REDIRECT_URL=http://localhost:5173/oauth/failure
AUTH_OAUTH2_COOKIE_SECURE=false

KAFKA_BOOTSTRAP_SERVERS=kafka:19092
AUTH_KAFKA_PRODUCER_ENABLED=true
AUTH_OUTBOX_PUBLISH_ENABLED=true
AUTH_OUTBOX_RETRY_ENABLED=true
AUTH_KAFKA_CONSUMER_ENABLED=false

AUTH_MINIO_ENABLED=true
AUTH_MINIO_ENDPOINT=http://minio:9000
AUTH_MINIO_PUBLIC_URL=http://localhost:9000/2hands-avatar
AUTH_MINIO_ACCESS_KEY=admin
AUTH_MINIO_SECRET_KEY=password123
MINIO_AVATAR_BUCKET=2hands-avatar
