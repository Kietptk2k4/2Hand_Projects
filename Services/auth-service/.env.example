CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DB_URL=jdbc:postgresql://localhost:5432/auth_db
DB_USERNAME=postgres
DB_PASSWORD=123456

REDIS_HOST=localhost
REDIS_PORT=6379

JWT_ACCESS_SECRET=change-me-access-secret-minimum-32-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-minimum-32-characters

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Kafka — hạng mục 1: bật cả producer + outbox publish để test gửi topic
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
AUTH_KAFKA_PRODUCER_ENABLED=true
AUTH_OUTBOX_PUBLISH_ENABLED=true
AUTH_OUTBOX_RETRY_ENABLED=true

# POST /api/v1/auth/verify-email — giới hạn số lần thử OTP theo IP (chống brute-force).
# Áp dụng trước khi kiểm tra mã; vượt ngưỡng trả 429 VERIFY_EMAIL_RATE_LIMITED.
# Mặc định application.yml: 10 lần / 900 giây (15 phút).
AUTH_VERIFY_EMAIL_RATE_LIMIT_MAX_ATTEMPTS=10
AUTH_VERIFY_EMAIL_RATE_LIMIT_WINDOW_SECONDS=900
