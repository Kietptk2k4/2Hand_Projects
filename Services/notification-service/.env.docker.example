# Docker Compose env template (safe to commit).
# Setup: cd Infrastructure && ./scripts/setup-docker-env.ps1

SERVER_PORT=3005
SPRING_PROFILES_ACTIVE=dev
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DB_URL=jdbc:postgresql://postgres-notification:5432/notification_db
DB_USERNAME=postgres
DB_PASSWORD=123456

REDIS_HOST=redis
REDIS_PORT=6379

JWT_ACCESS_SECRET=2hands-docker-dev-access-secret-min-32-chars
JWT_REFRESH_SECRET=2hands-docker-dev-refresh-secret-min-32-chars

NOTIFICATION_INTERNAL_INGEST_ENABLED=true
NOTIFICATION_INTERNAL_API_KEY=dev-internal-key

NOTIFICATION_KAFKA_CONSUMER_ENABLED=true
NOTIFICATION_KAFKA_BOOTSTRAP_SERVERS=kafka:19092
NOTIFICATION_KAFKA_CONSUMER_GROUP_ID=notification-domain-events-docker

NOTIFICATION_PROCESS_EVENTS_ENABLED=true
NOTIFICATION_RETRY_EVENTS_ENABLED=true
NOTIFICATION_RETRY_EVENTS_BASE_BACKOFF_SECONDS=30
NOTIFICATION_RETRY_EVENTS_MAX_BACKOFF_SECONDS=3600
NOTIFICATION_RETRY_DELIVERY_ENABLED=false
NOTIFICATION_CLEANUP_INVALID_DEVICE_TOKENS_ENABLED=false
NOTIFICATION_CLEANUP_OLD_NOTIFICATIONS_ENABLED=false
NOTIFICATION_PROCESS_EVENTS_CRON=0/5 * * * * *

NOTIFICATION_FCM_ENABLED=false
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_EMAIL_PROVIDER=smtp
SPRING_MAIL_HOST=mailhog
SPRING_MAIL_PORT=1025
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=false
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=false
NOTIFICATION_EMAIL_FROM=noreply@2hands.local
NOTIFICATION_EMAIL_FROM_NAME=2Hands
NOTIFICATION_EMAIL_PASSWORD_RESET_LINK_BASE_URL=http://localhost:5173/auth/reset-password?token={{token}}
