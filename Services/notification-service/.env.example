SERVER_PORT=3005
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DB_URL=jdbc:postgresql://localhost:5435/notification_db
DB_USERNAME=postgres
DB_PASSWORD=123456

REDIS_HOST=localhost
REDIS_PORT=6379

JWT_ACCESS_SECRET=change-me-access-secret-minimum-32-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-minimum-32-characters

NOTIFICATION_INTERNAL_INGEST_ENABLED=true
NOTIFICATION_INTERNAL_API_KEY=dev-internal-key

# Kafka hạng mục 2A/2B — consume domain events (auth email, social engagement, …) + process worker
# Hạng mục 4: cần consumer + process bật để nhận social.post.liked | social.comment.created | social.user.followed
# Xem docs/kafka/kafka_section_4.md
# Bắt buộc true cho E2E MailHog; nếu false → notification_events mãi PENDING, không có mail.
NOTIFICATION_KAFKA_CONSUMER_ENABLED=true
NOTIFICATION_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
NOTIFICATION_KAFKA_CONSUMER_GROUP_ID=notification-domain-events

# Bắt buộc true để scheduler xử lý PENDING → gửi email (2A/2B).
NOTIFICATION_PROCESS_EVENTS_ENABLED=true
NOTIFICATION_RETRY_EVENTS_ENABLED=true
NOTIFICATION_RETRY_EVENTS_BASE_BACKOFF_SECONDS=30
NOTIFICATION_RETRY_EVENTS_MAX_BACKOFF_SECONDS=3600
NOTIFICATION_RETRY_DELIVERY_ENABLED=false
NOTIFICATION_CLEANUP_INVALID_DEVICE_TOKENS_ENABLED=false
NOTIFICATION_CLEANUP_OLD_NOTIFICATIONS_ENABLED=false

NOTIFICATION_FCM_ENABLED=false

# Hạng mục 2B — SMTP qua MailHog (logging | smtp). Dev: smtp + MailHog trên localhost:1025
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_EMAIL_PROVIDER=smtp

SPRING_MAIL_HOST=localhost
SPRING_MAIL_PORT=1025
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=false
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=false

NOTIFICATION_EMAIL_FROM=noreply@2hands.local
NOTIFICATION_EMAIL_FROM_NAME=2Hands

# Email verify = OTP 6 chữ số only (không gửi magic link). Template dùng verification_code.
# NOTIFICATION_EMAIL_VERIFICATION_LINK_BASE_URL không dùng cho EMAIL_VERIFICATION_REQUESTED.
# Optional, unused for OTP verify — có thể bỏ qua hoặc để comment dòng dưới.
# NOTIFICATION_EMAIL_VERIFICATION_LINK_BASE_URL=https://2hands.vn/verify-email

# Forgot password: reset link (FE local). {{token}} được thay bởi Auth payload.
NOTIFICATION_EMAIL_PASSWORD_RESET_LINK_BASE_URL=http://localhost:5173/auth/reset-password?token={{token}}

# Auth (reference only — cấu hình trên auth-service/.env, không chạy trong notification):
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# AUTH_KAFKA_PRODUCER_ENABLED=true
# AUTH_OUTBOX_PUBLISH_ENABLED=true
