# Docker Compose env template (safe to commit).
# Setup: cd Infrastructure && ./scripts/setup-docker-env.ps1

SERVER_PORT=3002
SPRING_PROFILES_ACTIVE=dev
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DB_URL=jdbc:postgresql://postgres-social:5432/social_db
DB_USERNAME=postgres
DB_PASSWORD=123456

MONGO_URI=mongodb://mongodb:27017/social_db

REDIS_HOST=redis
REDIS_PORT=6379

JWT_ACCESS_SECRET=2hands-docker-dev-access-secret-min-32-chars
JWT_REFRESH_SECRET=2hands-docker-dev-refresh-secret-min-32-chars

SOCIAL_MINIO_ENABLED=true
SOCIAL_MINIO_ENDPOINT=http://minio:9000
SOCIAL_MINIO_PUBLIC_URL=http://localhost:9000/2hands-social-post
SOCIAL_MINIO_ACCESS_KEY=admin
SOCIAL_MINIO_SECRET_KEY=password123
MINIO_SOCIAL_POST_BUCKET=2hands-social-post
SOCIAL_MINIO_PUBLIC_PATH_PREFIX=

KAFKA_BOOTSTRAP_SERVERS=kafka:19092
SOCIAL_KAFKA_CONSUMER_ENABLED=true
SOCIAL_KAFKA_PRODUCER_ENABLED=true
SOCIAL_OUTBOX_PUBLISH_ENABLED=true
SOCIAL_OUTBOX_RETRY_ENABLED=true

COMMERCE_SERVICE_BASE_URL=http://commerce-service:3003
