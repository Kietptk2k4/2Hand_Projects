CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DB_URL=jdbc:postgresql://localhost:5433/social_db
DB_USERNAME=postgres
DB_PASSWORD=123456

MONGO_URI=mongodb://localhost:27017/social_db

REDIS_HOST=localhost
REDIS_PORT=6379

JWT_ACCESS_SECRET=change-me-access-secret-minimum-32-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-minimum-32-characters

SOCIAL_MINIO_ENABLED=false

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Hạng mục 3 — consume Auth/Admin → Mongo user_projections (+ admin.post.moderated)
# Hạng mục 6 — consume admin.user.* + admin.post.moderated (cùng SOCIAL_KAFKA_CONSUMER_ENABLED) — kafka_section_6.md
# Dev local: true khi test projection. Production do ops set.
SOCIAL_KAFKA_CONSUMER_ENABLED=true

# Hạng mục 4 — publish engagement → Notification (POST_LIKED, COMMENT_CREATED, USER_FOLLOWED)
SOCIAL_KAFKA_PRODUCER_ENABLED=true
SOCIAL_OUTBOX_PUBLISH_ENABLED=true
SOCIAL_OUTBOX_RETRY_ENABLED=true
