CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DB_URL=jdbc:postgresql://localhost:5433/social_db
DB_USERNAME=postgres
DB_PASSWORD=123456

MONGO_URI=mongodb://localhost:27017/social_db

REDIS_HOST=localhost
REDIS_PORT=6379

JWT_ACCESS_SECRET=acess_screet_6868_AKA_Phan_Tuan_Kiet_N22dccn145
JWT_REFRESH_SECRET=refresh_screet_9191_AKA_Phan_Tuan_Kiet_N22dccn145

SOCIAL_MINIO_ENABLED=true
SOCIAL_MINIO_ENDPOINT=http://localhost:9000
# Docker: endpoint=http://minio:9000, public-url=http://localhost:9000/... (presign host auto-resolved)
SOCIAL_MINIO_PUBLIC_URL=http://localhost:9000/2hands-social-post
SOCIAL_MINIO_ACCESS_KEY=admin
SOCIAL_MINIO_SECRET_KEY=password123
MINIO_SOCIAL_POST_BUCKET=2hands-social-post
# Dev local (MinIO trực tiếp): để trống — URL = {PUBLIC_URL}/posts/{userId}/...
# Production CDN: social — URL = https://cdn.2hands.vn/social/posts/...
SOCIAL_MINIO_PUBLIC_PATH_PREFIX=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Hạng mục 3 — consume auth.user.* → user_projections (kafka_section_3.md)
# Hạng mục 7 — Admin enforcement → user_projections (admin.user.*; cùng SOCIAL_KAFKA_CONSUMER_ENABLED mục 3) — kafka_section_7.md
# Hạng mục 6 — admin publish E2E (tổng hợp) — kafka_section_6.md
# Hạng mục 9 — admin.post.moderated → posts (group social-post-moderated) — kafka_section_9.md
# admin.comment.moderated|restored → comments (group social-comment-moderated)
# Một flag SOCIAL_KAFKA_CONSUMER_ENABLED bật auth + admin user + post listeners.
# Dev local: true khi test projection. Production do ops set.
SOCIAL_KAFKA_CONSUMER_ENABLED=true

# Commerce integration (product tag snapshots on create/edit post)
COMMERCE_SERVICE_BASE_URL=http://localhost:3003

# Hạng mục 4 — publish engagement → Notification (POST_LIKED, COMMENT_CREATED, USER_FOLLOWED)
SOCIAL_KAFKA_PRODUCER_ENABLED=true
SOCIAL_OUTBOX_PUBLISH_ENABLED=true
SOCIAL_OUTBOX_RETRY_ENABLED=true
