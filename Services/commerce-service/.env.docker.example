# Docker Compose env template (safe to commit).
# Setup: cd Infrastructure && ./scripts/setup-docker-env.ps1

SERVER_PORT=3003
SPRING_PROFILES_ACTIVE=dev
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DB_URL=jdbc:postgresql://postgres-commerce:5432/commerce_db
DB_USERNAME=postgres
DB_PASSWORD=123456

REDIS_HOST=redis
REDIS_PORT=6379

JWT_ACCESS_SECRET=2hands-docker-dev-access-secret-min-32-chars
JWT_REFRESH_SECRET=2hands-docker-dev-refresh-secret-min-32-chars

KAFKA_BOOTSTRAP_SERVERS=kafka:19092
COMMERCE_KAFKA_PRODUCER_ENABLED=true
COMMERCE_OUTBOX_PUBLISH_ENABLED=true
COMMERCE_OUTBOX_RETRY_ENABLED=true

COMMERCE_AUTH_INTEGRATION_ENABLED=true
COMMERCE_AUTH_INTEGRATION_BASE_URL=http://auth-service:3001

COMMERCE_AUTO_CANCEL_UNPAID_ORDER_ENABLED=false
COMMERCE_AUTO_COMPLETE_DELIVERED_ORDER_ENABLED=false
COMMERCE_SYNC_CART_ITEM_STATUS_ENABLED=false

COMMERCE_CHECKOUT_COD_ONLY_ENABLED=false
COMMERCE_PLATFORM_COMMISSION_RATE=0.10
COMMERCE_MIN_PAYOUT_AMOUNT=100000

COMMERCE_PAYOS_ENABLED=false
COMMERCE_PAYOS_MOCK_FALLBACK_ENABLED=true
COMMERCE_PAYOS_RETURN_URL=http://localhost:5173/commerce/checkout/payment-result
COMMERCE_PAYOS_CANCEL_URL=http://localhost:5173/commerce/checkout/payment-result

COMMERCE_VNPAY_ENABLED=true
COMMERCE_VNPAY_MOCK_FALLBACK_ENABLED=true
COMMERCE_VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
COMMERCE_VNPAY_RETURN_URL=http://localhost:3003/commerce/api/v1/payments/vnpay/return
COMMERCE_VNPAY_FRONTEND_RETURN_BASE_URL=http://localhost:5173

COMMERCE_GHN_ENABLED=false
COMMERCE_GHN_MOCK_FALLBACK_ENABLED=true
COMMERCE_GHN_BASE_URL=https://dev-online-gateway.ghn.vn
COMMERCE_GHN_DEFAULT_SERVICE_TYPE_ID=2

COMMERCE_MINIO_ENABLED=true
COMMERCE_MINIO_ENDPOINT=http://minio:9000
COMMERCE_MINIO_PUBLIC_URL=http://localhost:9000
COMMERCE_MINIO_ACCESS_KEY=admin
COMMERCE_MINIO_SECRET_KEY=password123
COMMERCE_MINIO_BUCKET_PRODUCT=2hands-commerce-product
COMMERCE_MINIO_BUCKET_REVIEW=2hands-commerce-review
COMMERCE_MINIO_BUCKET_SHOP=2hands-commerce-shop
