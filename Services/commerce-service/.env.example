CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DB_URL=jdbc:postgresql://localhost:5434/commerce_db
DB_USERNAME=postgres
DB_PASSWORD=123456

REDIS_HOST=localhost
REDIS_PORT=6379

JWT_ACCESS_SECRET=acess_screet_6868_AKA_Phan_Tuan_Kiet_N22dccn145
JWT_REFRESH_SECRET=refresh_screet_9191_AKA_Phan_Tuan_Kiet_N22dccn145

# Kafka — hạng mục 1: producer/outbox infrastructure
# Hạng mục 5: publish order/payment/shipment → Notification (docs/kafka/kafka_section_5.md)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
COMMERCE_KAFKA_PRODUCER_ENABLED=true
COMMERCE_OUTBOX_PUBLISH_ENABLED=true
COMMERCE_OUTBOX_RETRY_ENABLED=true

COMMERCE_AUTO_CANCEL_UNPAID_ORDER_ENABLED=false
COMMERCE_AUTO_CANCEL_UNPAID_ORDER_CRON=0 */10 * * * *
COMMERCE_AUTO_CANCEL_UNPAID_ORDER_BATCH_SIZE=50
COMMERCE_AUTO_CANCEL_UNPAID_ORDER_TTL_MINUTES=30

COMMERCE_AUTO_COMPLETE_DELIVERED_ORDER_ENABLED=false
COMMERCE_AUTO_COMPLETE_DELIVERED_ORDER_CRON=0 0 * * * *
COMMERCE_AUTO_COMPLETE_DELIVERED_ORDER_BATCH_SIZE=50
COMMERCE_AUTO_COMPLETE_DELIVERED_ORDER_WINDOW_DAYS=7

COMMERCE_SYNC_CART_ITEM_STATUS_ENABLED=false
COMMERCE_SYNC_CART_ITEM_STATUS_CRON=0 */5 * * * *
COMMERCE_SYNC_CART_ITEM_STATUS_BATCH_SIZE=100

# Phase 1: COD-only checkout (reject online payment at checkout). false = cho phep VNPay + COD.
COMMERCE_CHECKOUT_COD_ONLY_ENABLED=false

# Phase 3: seller ledger commission rate on order_item.final_price (default 10%).
COMMERCE_PLATFORM_COMMISSION_RATE=0.10
COMMERCE_MIN_PAYOUT_AMOUNT=100000

COMMERCE_PAYOS_ENABLED=false
COMMERCE_PAYOS_BASE_URL=https://api-merchant.payos.vn
COMMERCE_PAYOS_CLIENT_ID=
COMMERCE_PAYOS_API_KEY=
COMMERCE_PAYOS_CHECKSUM_KEY=
COMMERCE_PAYOS_RETURN_URL=http://localhost:5173/commerce/checkout/payment-result
COMMERCE_PAYOS_CANCEL_URL=http://localhost:5173/commerce/checkout/payment-result
COMMERCE_PAYOS_MOCK_FALLBACK_ENABLED=true
# PayOS webhook verify uses CHECKSUM_KEY above — not used by commerce-service:
COMMERCE_PAYOS_WEBHOOK_SECRET=
# PayOS webhook URL (configure on my.payos.vn, not here). Local dev via ngrok:
#   cd Infrastructure && docker compose -f docker-compose.yml -f docker-compose.payos.yml --profile payos up -d ngrok-commerce
#   ./scripts/print-payos-webhook-url.ps1

# VNPay — sandbox: https://sandbox.vnpayment.vn/devreg/
COMMERCE_VNPAY_ENABLED=true
COMMERCE_VNPAY_MOCK_FALLBACK_ENABLED=true
COMMERCE_VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
COMMERCE_VNPAY_RETURN_URL=http://localhost:3003/commerce/api/v1/payments/vnpay/return
COMMERCE_VNPAY_FRONTEND_RETURN_BASE_URL=http://localhost:5173
# COMMERCE_VNPAY_TMN_CODE=
# COMMERCE_VNPAY_HASH_SECRET=

# GHN staging: https://dev-online-gateway.ghn.vn | production: https://online-gateway.ghn.vn
COMMERCE_GHN_ENABLED=false
COMMERCE_GHN_MOCK_FALLBACK_ENABLED=true
COMMERCE_GHN_BASE_URL=https://dev-online-gateway.ghn.vn
# Token: GHN portal -> tab "Chu cua hang" -> "Xem"
COMMERCE_GHN_TOKEN=
# Shop _id from "Quan ly cua hang" or POST /shop/all (not Client ID)
COMMERCE_GHN_SHOP_ID=
# Dev: leave empty to skip webhook auth. Prod: random secret agreed with GHN support.
COMMERCE_GHN_WEBHOOK_SECRET=
# Default GHN service type: 1=Nhanh, 2=Chuan, 3=Tiet kiem (see available-services API)
COMMERCE_GHN_DEFAULT_SERVICE_TYPE_ID=2
# Optional override: pin a specific service_id from available-services
COMMERCE_GHN_DEFAULT_SERVICE_ID=
# Default parcel size (cm) for GHN calculate-fee when cart has no dimensions
COMMERCE_GHN_DEFAULT_PACKAGE_LENGTH_CM=20
COMMERCE_GHN_DEFAULT_PACKAGE_WIDTH_CM=20
COMMERCE_GHN_DEFAULT_PACKAGE_HEIGHT_CM=10
# Auto-sync on GET tracking: min seconds between GHN Order Info calls (0 = no cooldown)
COMMERCE_GHN_TRACK_SYNC_COOLDOWN_SECONDS=300
# Print label token TTL from GHN docs (minutes)
COMMERCE_GHN_PRINT_TOKEN_TTL_MINUTES=30
# Optional override; default derives from COMMERCE_GHN_BASE_URL + /a5/public-api
COMMERCE_GHN_PRINT_BASE_URL=


# MinIO (shared Infrastructure/docker-compose — docs/engineering_rules/commerce-object-storage.md)
# When enabled, avatar_url/cover_url must contain shop bucket path.
COMMERCE_MINIO_ENABLED=true
COMMERCE_MINIO_ENDPOINT=http://localhost:9000
COMMERCE_MINIO_PUBLIC_URL=http://localhost:9000
COMMERCE_MINIO_ACCESS_KEY=admin
COMMERCE_MINIO_SECRET_KEY=password123
COMMERCE_MINIO_BUCKET_PRODUCT=2hands-commerce-product
COMMERCE_MINIO_BUCKET_REVIEW=2hands-commerce-review
COMMERCE_MINIO_BUCKET_SHOP=2hands-commerce-shop
COMMERCE_PRODUCT_MEDIA_MAX_FILE_SIZE_BYTES=5242880
COMMERCE_PRODUCT_MEDIA_MAX_VIDEO_FILE_SIZE_BYTES=52428800
COMMERCE_PRODUCT_MEDIA_MAX_COUNT=10
COMMERCE_PRODUCT_MEDIA_MAX_VIDEO_COUNT=1

# COMMERCE_AUTH_INTEGRATION_ENABLED=true
# COMMERCE_AUTH_INTEGRATION_BASE_URL=http://auth-service:3001