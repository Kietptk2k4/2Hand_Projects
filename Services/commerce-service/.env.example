DB_URL=jdbc:postgresql://localhost:5434/commerce_db
DB_USERNAME=postgres
DB_PASSWORD=123456

REDIS_HOST=localhost
REDIS_PORT=6379

JWT_ACCESS_SECRET=change-me-access-secret-minimum-32-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-minimum-32-characters

COMMERCE_OUTBOX_PUBLISH_ENABLED=false
COMMERCE_OUTBOX_RETRY_ENABLED=false

COMMERCE_PAYOS_ENABLED=false
COMMERCE_PAYOS_WEBHOOK_SECRET=

COMMERCE_GHN_ENABLED=false
COMMERCE_GHN_TOKEN=
COMMERCE_GHN_WEBHOOK_SECRET=

# MinIO (shared Infrastructure/docker-compose — docs/engineering_rules/commerce-object-storage.md)
COMMERCE_MINIO_ENABLED=false
COMMERCE_MINIO_ENDPOINT=http://localhost:9000
COMMERCE_MINIO_PUBLIC_URL=http://localhost:9000
COMMERCE_MINIO_BUCKET_PRODUCT=2hands-commerce-product
COMMERCE_MINIO_BUCKET_REVIEW=2hands-commerce-review
COMMERCE_MINIO_BUCKET_SHOP=2hands-commerce-shop
