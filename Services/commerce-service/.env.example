CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DB_URL=jdbc:postgresql://localhost:5434/commerce_db
DB_USERNAME=postgres
DB_PASSWORD=123456

REDIS_HOST=localhost
REDIS_PORT=6379

JWT_ACCESS_SECRET=change-me-access-secret-minimum-32-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-minimum-32-characters

# Kafka — hạng mục 1: producer/outbox infrastructure
# Hạng mục 5: publish order/payment/shipment → Notification (docs/kafka/kafka_section_5.md)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
COMMERCE_KAFKA_PRODUCER_ENABLED=true
COMMERCE_OUTBOX_PUBLISH_ENABLED=true
COMMERCE_OUTBOX_RETRY_ENABLED=true

COMMERCE_AUTO_CANCEL_UNPAID_ORDER_ENABLED=false
COMMERCE_AUTO_CANCEL_UNPAID_ORDER_CRON=0 */10 * * * *
COMMERCE_AUTO_CANCEL_UNPAID_ORDER_BATCH_SIZE=50
COMMERCE_AUTO_CANCEL_UNPAID_ORDER_TTL_MINUTES=30

COMMERCE_AUTO_COMPLETE_DELIVERED_ORDER_ENABLED=false
COMMERCE_AUTO_COMPLETE_DELIVERED_ORDER_CRON=0 0 * * * *
COMMERCE_AUTO_COMPLETE_DELIVERED_ORDER_BATCH_SIZE=50
COMMERCE_AUTO_COMPLETE_DELIVERED_ORDER_WINDOW_DAYS=7

COMMERCE_SYNC_CART_ITEM_STATUS_ENABLED=false
COMMERCE_SYNC_CART_ITEM_STATUS_CRON=0 */5 * * * *
COMMERCE_SYNC_CART_ITEM_STATUS_BATCH_SIZE=100

COMMERCE_PAYOS_ENABLED=false
COMMERCE_PAYOS_BASE_URL=https://api-merchant.payos.vn
COMMERCE_PAYOS_CLIENT_ID=
COMMERCE_PAYOS_API_KEY=
COMMERCE_PAYOS_CHECKSUM_KEY=
COMMERCE_PAYOS_RETURN_URL=http://localhost:3000/payments/payos/return
COMMERCE_PAYOS_CANCEL_URL=http://localhost:3000/payments/payos/cancel
COMMERCE_PAYOS_MOCK_FALLBACK_ENABLED=true
COMMERCE_PAYOS_WEBHOOK_SECRET=

COMMERCE_GHN_ENABLED=false
COMMERCE_GHN_MOCK_FALLBACK_ENABLED=true
COMMERCE_GHN_TOKEN=
COMMERCE_GHN_WEBHOOK_SECRET=

# MinIO (shared Infrastructure/docker-compose — docs/engineering_rules/commerce-object-storage.md)
# When enabled, avatar_url/cover_url must contain shop bucket path.
COMMERCE_MINIO_ENABLED=true
COMMERCE_MINIO_ENDPOINT=http://localhost:9000
COMMERCE_MINIO_PUBLIC_URL=http://localhost:9000
COMMERCE_MINIO_ACCESS_KEY=admin
COMMERCE_MINIO_SECRET_KEY=password123
COMMERCE_MINIO_BUCKET_PRODUCT=2hands-commerce-product
COMMERCE_MINIO_BUCKET_REVIEW=2hands-commerce-review
COMMERCE_MINIO_BUCKET_SHOP=2hands-commerce-shop
