# syntax=docker/dockerfile:1

FROM node:22-alpine AS dev
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
EXPOSE 5173
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]

FROM node:22-alpine AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .

ARG VITE_AUTH_SERVICE_BASE_URL=http://localhost:3001
ARG VITE_SOCIAL_SERVICE_BASE_URL=http://localhost:3002
ARG VITE_COMMERCE_SERVICE_BASE_URL=http://localhost:3003
ARG VITE_ADMIN_SERVICE_BASE_URL=http://localhost:3004
ARG VITE_NOTIFICATION_SERVICE_BASE_URL=http://localhost:3005
ARG VITE_USE_MOCK=false
ARG VITE_COMMERCE_CHECKOUT_COD_ONLY_ENABLED=false

ENV VITE_AUTH_SERVICE_BASE_URL=$VITE_AUTH_SERVICE_BASE_URL
ENV VITE_SOCIAL_SERVICE_BASE_URL=$VITE_SOCIAL_SERVICE_BASE_URL
ENV VITE_COMMERCE_SERVICE_BASE_URL=$VITE_COMMERCE_SERVICE_BASE_URL
ENV VITE_ADMIN_SERVICE_BASE_URL=$VITE_ADMIN_SERVICE_BASE_URL
ENV VITE_NOTIFICATION_SERVICE_BASE_URL=$VITE_NOTIFICATION_SERVICE_BASE_URL
ENV VITE_USE_MOCK=$VITE_USE_MOCK
ENV VITE_COMMERCE_CHECKOUT_COD_ONLY_ENABLED=$VITE_COMMERCE_CHECKOUT_COD_ONLY_ENABLED

RUN npm run build

FROM nginx:1.27-alpine AS production
COPY nginx/default.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80