# Vite local dev against ngrok gateway (hybrid: localhost FE + ngrok API).
# Generate: cd Infrastructure && ./scripts/apply-ngrok-gateway-env.ps1
# Requires ngrok-gateway + dev-gateway running. Restart npm run dev after sync.
# Axios sends ngrok-skip-browser-warning automatically (see ngrokGatewayHeaders.js).
VITE_AUTH_SERVICE_BASE_URL=https://YOUR-NGROK-HOST.ngrok-free.dev
VITE_SOCIAL_SERVICE_BASE_URL=https://YOUR-NGROK-HOST.ngrok-free.dev
VITE_COMMERCE_SERVICE_BASE_URL=https://YOUR-NGROK-HOST.ngrok-free.dev
VITE_ADMIN_SERVICE_BASE_URL=https://YOUR-NGROK-HOST.ngrok-free.dev
VITE_NOTIFICATION_SERVICE_BASE_URL=https://YOUR-NGROK-HOST.ngrok-free.dev
VITE_USE_MOCK=false
