# CORS: backend services allow http://localhost:5173 via CORS_ALLOWED_ORIGINS (see each service .env).
VITE_AUTH_SERVICE_BASE_URL=http://localhost:3001
# Port backend social-service (README: 3002). MSW intercept API khi VITE_USE_MOCK=true.
VITE_SOCIAL_SERVICE_BASE_URL=http://localhost:3002
# Port backend commerce-service. MSW intercept API khi VITE_USE_MOCK=true.
VITE_COMMERCE_SERVICE_BASE_URL=http://localhost:3003
# Port backend admin-service (README: 3004). Bat khi VITE_USE_MOCK=false.
VITE_ADMIN_SERVICE_BASE_URL=http://localhost:3004
# Port backend notification-service (README: 3005).
VITE_NOTIFICATION_SERVICE_BASE_URL=http://localhost:3005
# Bat mock MSW (auth + social + commerce). Can restart `npm run dev` sau khi doi.
VITE_USE_MOCK=false
# Checkout: false = VNPay + COD. true = chi COD. Khop COMMERCE_CHECKOUT_COD_ONLY_ENABLED tren commerce-service.
VITE_COMMERCE_CHECKOUT_COD_ONLY_ENABLED=false
# Bat PayOS tren UI (can COMMERCE_PAYOS_ENABLED tren BE). Mac dinh an.
# VITE_COMMERCE_CHECKOUT_PAYOS_ENABLED=false