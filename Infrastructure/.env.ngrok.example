# ngrok authtoken - https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# commerce-service port on host (legacy payos profile only)
COMMERCE_HOST_PORT=3003

# --- Remote demo (profile ngrok) ---
# After ./scripts/print-ngrok-urls.ps1, set GATEWAY_HTTPS_URL (no trailing slash).
# Example: GATEWAY_HTTPS_URL=https://abc123.ngrok-free.app
GATEWAY_HTTPS_URL=

# Paste into Services/*/.env.docker.local when using --profile ngrok (see .env.docker.ngrok.example per service).
#
# Shared checklist (replace {GATEWAY} with GATEWAY_HTTPS_URL):
#   CORS_ALLOWED_ORIGINS={GATEWAY}
#   AUTH_OAUTH2_SUCCESS_REDIRECT_URL={GATEWAY}/oauth/success
#   AUTH_OAUTH2_FAILURE_REDIRECT_URL={GATEWAY}/oauth/failure
#   AUTH_OAUTH2_COOKIE_SECURE=true
#   Google OAuth redirect URI: {GATEWAY}/login/oauth2/code/google
#   Facebook OAuth redirect URI: {GATEWAY}/login/oauth2/code/facebook
#   AUTH_MINIO_PRESIGNED_ENDPOINT={GATEWAY}
#   AUTH_MINIO_PUBLIC_URL={GATEWAY}/2hands-avatar
#   SOCIAL_MINIO_PRESIGNED_ENDPOINT={GATEWAY}
#   SOCIAL_MINIO_PUBLIC_URL={GATEWAY}/2hands-social-post
#   COMMERCE_MINIO_PRESIGNED_ENDPOINT={GATEWAY}
#   COMMERCE_MINIO_PUBLIC_URL={GATEWAY}
#   COMMERCE_PAYOS_RETURN_URL={GATEWAY}/commerce/checkout/payment-result
#   COMMERCE_PAYOS_CANCEL_URL={GATEWAY}/commerce/checkout/payment-result
#
# Frontend build (all VITE_*_SERVICE_BASE_URL={GATEWAY})
# Mobile .env (all EXPO_PUBLIC_*_BASE_URL={GATEWAY}, EXPO_PUBLIC_DEV_HOST=ngrok host without scheme)
#
# PayOS webhook: {GATEWAY}/commerce/api/v1/payments/webhooks/payos
